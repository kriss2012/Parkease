NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/parkease

# JWT
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=change_this_other_secret_key
JWT_REFRESH_EXPIRE=7d

# QR signing secret (HMAC)
QR_SECRET=change_this_qr_secret

# Client URL (CORS)
CLIENT_URL=http://localhost:5173

# Email (Nodemailer - use Mailtrap/Gmail app password/etc.)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=ParkEase <no-reply@parkease.com>

# GST rate applied to bookings (percentage)
GST_RATE=18
